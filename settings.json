{
  "env": {
    "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
  },
  "model": "claude-opus-4-6",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -message 'Claude is now idle' -title 'Claude Code' -appIcon '/Applications/Claude.app/Contents/Resources/electron.icns' -contentImage '/Applications/Claude.app/Contents/Resources/electron.icns' -sound 'default'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -message 'Claude is waiting for your response' -title 'Claude Code' -appIcon '/Applications/Claude.app/Contents/Resources/electron.icns' -contentImage '/Applications/Claude.app/Contents/Resources/electron.icns' -sound 'default'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "learning-opportunities@learning-opportunities": true,
    "salesforce-ai-tools@aquiva-labs": true,
    "aidan-salesforce-skills@aidan-user-claude": true
  },
  "extraKnownMarketplaces": {
    "Aquiva": {
      "source": {
        "source": "git",
        "url": "https://github.com/aquivalabs/aquiva-skills.git"
      }
    },
    "learning-opportunities": {
      "source": {
        "source": "git",
        "url": "https://github.com/DrCatHicks/learning-opportunities.git"
      }
    },
    "aquiva-labs": {
      "source": {
        "source": "git",
        "url": "https://github.com/aquivalabs/salesforce-ai-tools.git"
      }
    },
    "aidan-user-claude": {
      "source": {
        "source": "github",
        "repo": "aquivalabs/aidan-user-claude"
      }
    }
  },
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
